#!/bin/sh
# bin/devconf — devconf CLI dispatcher

set -e

# ── Resolve DEVCONF_REPO from script's real location ─────────────────────────
_SELF="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
DEVCONF_REPO="$(cd "$(dirname "$_SELF")/.." && pwd)"
export DEVCONF_REPO

# ── Source libs ───────────────────────────────────────────────────────────────
. "${DEVCONF_REPO}/lib/utils.sh"
. "${DEVCONF_REPO}/lib/diff.sh"
. "${DEVCONF_REPO}/lib/hooks.sh"

# ── Hook runner ───────────────────────────────────────────────────────────────

# Walk configs/*/install.sh, set DC_CONFIG_DIR + DC_MODE, source each hook
_dc_run_hooks() {
    dc_detect_os
    for _hook in "${DEVCONF_REPO}"/configs/*/install.sh; do
        [ -f "$_hook" ] || continue
        DC_CONFIG_DIR="$(dirname "$_hook")"
        export DC_CONFIG_DIR
        _domain="$(basename "$DC_CONFIG_DIR")"
        dc_bold "[$_domain]"
        . "$_hook" || true
        echo ""
    done
}

# ── Top-level commands ────────────────────────────────────────────────────────

cmd_configure() {
    DC_MODE=configure
    export DC_MODE
    dc_bold "devconf configure"
    echo ""
    _dc_run_hooks
    dc_green "Done. You may need to: source $(dc_profile_file)"
}

cmd_sync() {
    dc_require_cmd git
    DC_MODE=sync
    export DC_MODE
    dc_bold "devconf sync"
    echo ""
    _dc_run_hooks

    # Commit changed configs
    if git -C "$DEVCONF_REPO" diff --quiet -- configs/ && \
       git -C "$DEVCONF_REPO" diff --cached --quiet -- configs/; then
        dc_ok "Nothing changed; no commit needed."
        return
    fi

    dc_bold "Changed files:"
    git -C "$DEVCONF_REPO" diff --name-only -- configs/
    git -C "$DEVCONF_REPO" diff --cached --name-only -- configs/
    echo ""

    git -C "$DEVCONF_REPO" add -- configs/

    _default_msg="sync: update configs from $(hostname)"
    printf 'Commit message [%s]: ' "$_default_msg"
    read -r _dc_msg
    [ -z "$_dc_msg" ] && _dc_msg="$_default_msg"
    git -C "$DEVCONF_REPO" commit -m "$_dc_msg"

    printf '\nPush to remote? [y/N] '
    read -r _dc_push
    case "$_dc_push" in
        y|Y) git -C "$DEVCONF_REPO" push; dc_ok "Pushed." ;;
        *)   dc_info "Not pushed. Run: git -C \"$DEVCONF_REPO\" push" ;;
    esac
}

cmd_update() {
    dc_bold "devconf update"
    echo ""
    dc_require_cmd git
    if ! git -C "$DEVCONF_REPO" pull --rebase; then
        dc_err "git pull --rebase failed. Resolve conflicts in $DEVCONF_REPO, then run: devconf configure"
        exit 1
    fi
    echo ""
    cmd_configure
}

cmd_remove() {
    _target="${1:-}"
    if [ "$_target" = "all" ]; then
        dc_bold "devconf remove all"
        echo ""
        for _hook in "${DEVCONF_REPO}"/configs/*/uninstall.sh; do
            [ -f "$_hook" ] || continue
            DC_CONFIG_DIR="$(dirname "$_hook")"
            export DC_CONFIG_DIR
            _domain="$(basename "$DC_CONFIG_DIR")"
            dc_bold "[$_domain]"
            dc_detect_os
            . "$_hook" || true
            echo ""
        done
    elif [ -n "$_target" ]; then
        _hook="${DEVCONF_REPO}/configs/${_target}/uninstall.sh"
        if [ ! -f "$_hook" ]; then
            dc_err "No uninstall hook for: $_target"
            exit 1
        fi
        DC_CONFIG_DIR="${DEVCONF_REPO}/configs/${_target}"
        export DC_CONFIG_DIR
        dc_detect_os
        dc_bold "devconf remove $_target"
        echo ""
        . "$_hook" || true
    else
        dc_red "Usage: devconf remove <module|all>"
        exit 1
    fi
}

cmd_help() {
    # Build module list from configs/ directory names
    _modules=""
    for _d in "${DEVCONF_REPO}"/configs/*/; do
        [ -d "$_d" ] || continue
        _mod="$(basename "$_d")"
        _modules="${_modules:+$_modules|}$_mod"
    done

    cat << EOF
devconf — developer config manager

Usage: devconf <command>

Commands:
  configure            Apply configs from repo to live system
  update               Pull latest repo changes, then configure
  sync                 Sync live configs back to repo and commit
  remove <module|all>  Remove a deployed config ($_modules|all)
  help                 Show this help message

Repo: https://github.com/codyhamilton/ansible-dev-config
EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${1:-}" in
    configure) cmd_configure ;;
    update)    cmd_update ;;
    sync)      cmd_sync ;;
    remove)    shift; cmd_remove "${1:-}" ;;
    help|--help|-h|"") cmd_help ;;
    *)
        dc_red "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
